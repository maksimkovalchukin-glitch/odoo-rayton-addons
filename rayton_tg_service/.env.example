# Telegram API credentials (for the SERVICE ACCOUNT — a real Telegram user)
# Get from: https://my.telegram.org → Log in → "API development tools" → Create app
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Session file name (without .session extension)
# The session file is created by auth.py and must persist on disk
TG_SESSION=rayton_service

# Your Telegram bot's @username (the bot that will be added to each group as admin)
TG_BOT_USERNAME=@your_bot_username

# Shared secret — Odoo sends this in X-Secret header
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SERVICE_SECRET=change_me_to_a_strong_random_secret
