<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Wizard form ── -->
    <record id="rayton_telegram_create_wizard_form" model="ir.ui.view">
        <field name="name">rayton.telegram.create.wizard.form</field>
        <field name="model">rayton.telegram.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Створити Telegram групу">
                <group>
                    <field name="title" placeholder="Назва нової TG групи"/>
                </group>
                <field name="member_ids"
                       placeholder="Почніть вводити ім'я...">
                    <tree editable="bottom">
                        <field name="name"/>
                        <field name="username"/>
                        <field name="role"/>
                        <field name="is_admin" widget="boolean_toggle" string="Адмін"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create" type="object"
                            string="🚀 Створити групу" class="btn-primary"/>
                    <button special="cancel" string="Скасувати" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Member list view ── -->
    <record id="rayton_telegram_member_view_list" model="ir.ui.view">
        <field name="name">rayton.telegram.member.list</field>
        <field name="model">rayton.telegram.member</field>
        <field name="arch" type="xml">
            <tree string="Учасники Telegram груп" editable="bottom">
                <header>
                    <button name="action_open_create_wizard" type="object"
                            string="➕ Створити нову TG групу" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="username"/>
                <field name="role" widget="badge"
                       decoration-success="role == 'mandatory'"
                       decoration-muted="role == 'optional'"/>
                <field name="is_admin" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- ── Member form view ── -->
    <record id="rayton_telegram_member_view_form" model="ir.ui.view">
        <field name="name">rayton.telegram.member.form</field>
        <field name="model">rayton.telegram.member</field>
        <field name="arch" type="xml">
            <form string="Учасник Telegram">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="username" placeholder="@ivan_manager"/>
                        <field name="role"/>
                        <field name="is_admin"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action: open wizard ── -->
    <record id="action_open_create_tg_group_wizard" model="ir.actions.act_window">
        <field name="name">Створити Telegram групу</field>
        <field name="res_model">rayton.telegram.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ── Action: members list ── -->
    <record id="rayton_telegram_member_action" model="ir.actions.act_window">
        <field name="name">Учасники Telegram груп</field>
        <field name="res_model">rayton.telegram.member</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Додайте учасників
            </p>
            <p>
                Учасники з роллю «Обов'язковий» автоматично підтягуються
                у wizard при створенні нової TG групи.
            </p>
        </field>
    </record>

    <!-- ── Menu under Project > Configuration ── -->
    <menuitem
        id="rayton_telegram_member_menu"
        name="Учасники Telegram груп"
        parent="project.menu_project_config"
        action="rayton_telegram_member_action"
        sequence="101"
    />

    <!-- ── Quick-create shortcut in Configuration menu ── -->
    <menuitem
        id="rayton_telegram_create_group_menu"
        name="➕ Створити TG групу"
        parent="project.menu_project_config"
        action="action_open_create_tg_group_wizard"
        sequence="102"
    />

</odoo>
