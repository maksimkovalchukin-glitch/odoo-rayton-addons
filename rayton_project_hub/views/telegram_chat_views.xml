<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Server action: Create new pool group via Telethon ── -->
    <record id="action_create_pool_group" model="ir.actions.server">
        <field name="name">Створити нову TG групу</field>
        <field name="model_id" ref="model_rayton_telegram_chat"/>
        <field name="binding_model_id" ref="model_rayton_telegram_chat"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_create_pool_group()</field>
    </record>

    <!-- ── List view ── -->
    <record id="rayton_telegram_chat_view_list" model="ir.ui.view">
        <field name="name">rayton.telegram.chat.list</field>
        <field name="model">rayton.telegram.chat</field>
        <field name="arch" type="xml">
            <tree string="Telegram групи" decoration-success="state == 'free'" decoration-muted="state == 'busy'">
                <header>
                    <button name="action_create_pool_group" type="object"
                            string="➕ Створити нову TG групу" class="btn-primary"/>
                </header>
                <control>
                    <button name="action_create_pool_group" type="object"
                            string="Створити нову TG групу"/>
                </control>
                <field name="name"/>
                <field name="tg_chat_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'free'"
                       decoration-warning="state == 'busy'"/>
                <field name="project_id"/>
                <field name="discuss_channel_id"/>
                <button name="action_release" type="object"
                        string="Звільнити" icon="fa-unlock"
                        invisible="state == 'free'"
                        confirm="Звільнити цю групу та від'язати від проекту?"/>
            </tree>
        </field>
    </record>

    <!-- ── Form view ── -->
    <record id="rayton_telegram_chat_view_form" model="ir.ui.view">
        <field name="name">rayton.telegram.chat.form</field>
        <field name="model">rayton.telegram.chat</field>
        <field name="arch" type="xml">
            <form string="Telegram група">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tg_chat_id" placeholder="-1003883870898"/>
                        <field name="state" widget="badge"
                               decoration-success="state == 'free'"
                               decoration-warning="state == 'busy'"/>
                        <field name="project_id" readonly="1"/>
                        <field name="discuss_channel_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="rayton_telegram_chat_action" model="ir.actions.act_window">
        <field name="name">Telegram групи (пул)</field>
        <field name="res_model">rayton.telegram.chat</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Додайте Telegram групи до пулу
            </p>
            <p>
                Створіть групи в Telegram, скопіюйте їх ID і додайте сюди.
                При ініціації проекту система автоматично призначить вільну групу.
            </p>
        </field>
    </record>

    <!-- ── Menu under Project > Configuration ── -->
    <menuitem
        id="rayton_telegram_chat_menu"
        name="Telegram групи"
        parent="project.menu_project_config"
        action="rayton_telegram_chat_action"
        sequence="100"
    />

</odoo>
