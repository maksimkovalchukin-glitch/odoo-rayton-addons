<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_period_wizard_form" model="ir.ui.view">
        <field name="name">rayton.kpi.period.wizard.form</field>
        <field name="model">rayton.kpi.period.wizard</field>
        <field name="arch" type="xml">
            <form string="КПІ Менеджерів — вибір місяця">
                <group>
                    <field name="period_date" string="Місяць"/>
                </group>
                <footer>
                    <button name="action_compute" string="Розрахувати КПІ"
                            type="object" class="btn-primary"/>
                    <button string="Скасувати" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kpi_period_wizard" model="ir.actions.act_window">
        <field name="name">КПІ Менеджерів</field>
        <field name="res_model">rayton.kpi.period.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
