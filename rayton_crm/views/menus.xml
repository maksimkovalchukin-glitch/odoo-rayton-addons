<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════
         Actions для ЛІДИ і НАГОДИ
    ══════════════════════════════════════════════════════════════════ -->

    <!-- ЛІДИ — канбан для розбору/кваліфікації (type='lead') -->
    <record id="action_leads_qualify_kanban" model="ir.actions.act_window">
        <field name="name">Ліди</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,activity</field>
        <field name="domain">['|', ('type', '=', 'lead'), ('type', '=', False)]</field>
        <field name="context">{'default_type': 'lead', 'default_team_id': 5}</field>
    </record>

    <!-- НАГОДИ — канбан кваліфікованих нагод (type='opportunity') -->
    <record id="action_opportunities_kanban" model="ir.actions.act_window">
        <field name="name">Нагоди</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,calendar,activity</field>
        <field name="domain">[('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity', 'default_team_id': 1}</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Структура меню CRM:
         ЛІДИ | НАГОДИ | Черга | Передача | КПІ | Дзвінки | Телефони | Звітність | Налаштування
    ══════════════════════════════════════════════════════════════════ -->

    <!-- ЛІДИ (seq=5): замінюємо action на kanban Оператори, показуємо операторам та кц -->
    <record id="crm.crm_menu_leads" model="ir.ui.menu">
        <field name="name">Ліди</field>
        <field name="sequence">5</field>
        <field name="action" ref="action_leads_qualify_kanban"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('rayton_crm.group_operator'),
            ref('rayton_crm.group_kc_head'),
            ref('base.group_erp_manager'),
        ])]"/>
    </record>

    <!-- НАГОДИ (seq=10): нове меню для менеджерів та адмінів -->
    <menuitem id="menu_crm_opportunities"
              name="Нагоди"
              parent="crm.crm_menu_root"
              action="action_opportunities_kanban"
              sequence="10"
              groups="rayton_crm.group_manager,rayton_crm.group_kc_head,base.group_erp_manager"/>

    <!-- Черга менеджерів (seq=20) — для керівника КЦ -->
    <menuitem id="menu_manager_queue"
              name="Черга менеджерів"
              parent="crm.crm_menu_root"
              action="action_manager_queue"
              sequence="20"
              groups="rayton_crm.group_kc_head"/>

    <!-- Передача лідів (seq=25) — для всіх -->
    <menuitem id="menu_lead_transfer"
              name="Передача лідів"
              parent="crm.crm_menu_root"
              action="action_lead_transfer"
              sequence="25"/>

    <!-- КПІ Менеджерів (seq=30) — для адмінів, керівника КЦ та менеджерів -->
    <menuitem id="menu_manager_kpi"
              name="КПІ Менеджерів"
              parent="crm.crm_menu_root"
              action="action_open_kpi_server"
              sequence="30"
              groups="base.group_erp_manager,rayton_crm.group_kc_head,rayton_crm.group_manager"/>

    <!-- Дзвінки Ringostat (seq=35) — для адмінів та керівника КЦ -->
    <menuitem id="menu_ringostat_calls"
              name="Дзвінки Ringostat"
              parent="crm.crm_menu_root"
              action="action_ringostat_calls"
              sequence="35"
              groups="base.group_erp_manager,rayton_crm.group_kc_head"/>

    <!-- Виключені телефони (seq=36) — тільки для адмінів -->
    <menuitem id="menu_ringostat_excluded"
              name="Виключені телефони"
              parent="crm.crm_menu_root"
              action="action_ringostat_excluded_phones"
              sequence="36"
              groups="base.group_erp_manager"/>

    <!-- Звітність — в кінці (seq=90), тільки для адмінів -->
    <record id="crm.crm_menu_report" model="ir.ui.menu">
        <field name="sequence">90</field>
        <field name="groups_id" eval="[(6, 0, [ref('base.group_erp_manager')])]"/>
    </record>

    <!-- Налаштування — в кінці (seq=95), тільки для адмінів -->
    <record id="crm.crm_menu_config" model="ir.ui.menu">
        <field name="sequence">95</field>
        <field name="groups_id" eval="[(6, 0, [ref('base.group_erp_manager')])]"/>
    </record>

    <!-- Продажі (стандартний підрозділ) — в кінці (seq=98), тільки для адмінів -->
    <record id="crm.crm_menu_sales" model="ir.ui.menu">
        <field name="sequence">98</field>
        <field name="groups_id" eval="[(6, 0, [ref('base.group_erp_manager')])]"/>
    </record>

    <!-- Імпорт і синхронізація — в кінці (seq=99), тільки для адмінів -->
    <record id="crm.menu_import_crm" model="ir.ui.menu">
        <field name="sequence">99</field>
        <field name="groups_id" eval="[(6, 0, [ref('base.group_erp_manager')])]"/>
    </record>
</odoo>
