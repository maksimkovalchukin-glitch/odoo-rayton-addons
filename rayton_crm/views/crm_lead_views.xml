<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Кнопки передачі + вкладка контактів на формі ліда/нагоди -->
    <record id="view_crm_lead_form_rayton" model="ir.ui.view">
        <field name="name">crm.lead.form.rayton</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Невидиме поле для умов invisible на кнопках -->
            <xpath expr="//sheet" position="inside">
                <field name="is_with_manager" invisible="True"/>
            </xpath>

            <!-- Ховаємо Очікуваний дохід і Імовірність — не потрібні -->
            <xpath expr="//div[contains(@class,'oe_title')]/h2" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <!-- Наші поля: тип проекту, споживання, банківський клієнт + нові поля угоди -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="project_type" string="Тип проекту"/>
                <field name="consumption" string="Споживання, МВт*год/міс"/>
                <field name="is_bank_client" string="Банківський клієнт"/>
                <field name="financing_type" string="Тип фінансування"/>
                <field name="power_ses_kw" string="Потужність СЕС, кВт"/>
                <field name="capacity_uze_kwh" string="Ємність УЗЕ, кВт·год"/>
            </xpath>

            <!-- Кнопки передачі в заголовку (перед кнопкою Won) -->
            <xpath expr="//button[@name='action_set_won_rainbowman']" position="before">
                <button name="action_transfer_to_manager"
                        string="📤 Передати менеджеру"
                        type="object"
                        class="btn-primary"
                        invisible="is_with_manager"
                        groups="rayton_crm.group_operator,rayton_crm.group_credit,rayton_crm.group_kc_head"/>
                <button name="action_return_to_kc"
                        string="🔄 Повернути на КЦ"
                        type="object"
                        class="btn-warning"
                        invisible="not is_with_manager"
                        groups="rayton_crm.group_manager"/>
            </xpath>

            <!-- Stat button кількість передач -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_transfer_to_manager"
                        class="oe_stat_button" icon="fa-exchange"
                        groups="rayton_crm.group_operator,rayton_crm.group_credit,rayton_crm.group_kc_head">
                    <field name="transfer_count" widget="statinfo" string="Передач"/>
                </button>
            </xpath>

            <!-- Вкладка контактів компанії -->
            <xpath expr="//page[@name='extra']" position="after">
                <page string="Контакти" name="rayton_contacts">
                    <field name="contact_ids" readonly="1"
                           context="{'list_view_ref': 'rayton_crm.view_partner_contact_in_lead'}"/>
                </page>
                <page string="Деталі угоди" name="rayton_deal">
                    <group string="Дати">
                        <field name="primary_calc_date" string="Дата первинних розрахунків"/>
                        <field name="measurement_date" string="Дата замірів"/>
                        <field name="advance_planned_date" string="Планова дата авансу"/>
                        <field name="advance_actual_date" string="Фактична дата авансу"/>
                    </group>
                    <group string="Технічна інформація">
                        <field name="project_number" string="Номер проекту"/>
                        <field name="loss_reason_text" string="Причина програшу"
                               invisible="not loss_reason_text"/>
                        <field name="pipedrive_deal_id" string="Pipedrive ID"
                               invisible="not pipedrive_deal_id"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- Кредитний спеціаліст угоди -->
    <record id="view_crm_opportunity_form_credit" model="ir.ui.view">
        <field name="name">crm.lead.form.credit.hint</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="credit_specialist_id" string="Кредитний спеціаліст"/>
            </xpath>
        </field>
    </record>
</odoo>
